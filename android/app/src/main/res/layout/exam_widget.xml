<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/exam_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: exam date + count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/exam_header_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/exam_header_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Countdown content -->
        <LinearLayout
            android:id="@+id/exam_countdown_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center_vertical">

            <!-- Course name directly -->
            <TextView
                android:id="@+id/exam_countdown_prefix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/exam_countdown_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/exam_countdown_days_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="天"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />
            </LinearLayout>

            <!-- Time only -->
            <TextView
                android:id="@+id/exam_countdown_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/exam_countdown_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Blue underline decoration -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@color/widget_text_accent" />
        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/exam_empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/exam_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_empty_text"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
