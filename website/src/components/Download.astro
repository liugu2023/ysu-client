---
import { Code, FileText, Download } from 'lucide-react';
import DownloadDialog from './DownloadDialog';
import { readFileSync } from 'fs';
import { resolve } from 'path';

const locale = Astro.currentLocale ?? 'zh';
const isEn = locale === 'en';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);

type ChangelogEntry = {
  version?: string;
  date?: string;
  prerelease?: boolean;
};

// Read latest stable version from changelog.json (generated by release.sh)
let version = '0.0.0';
let releaseDate = '';
try {
  const changelogPath = resolve('./src/data/changelog.json');
  const changelog = JSON.parse(readFileSync(changelogPath, 'utf-8')) as ChangelogEntry[];
  const latest = changelog.find((item) => item.prerelease !== true) ?? changelog[0];
  if (latest) {
    version = latest.version ?? version;
    releaseDate = latest.date ?? releaseDate;
  }
} catch {
  // Development fallback: read from package.json
  try {
    const pkgPath = resolve('../package.json');
    const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8'));
    version = pkg.version || '0.0.0';
  } catch {
    // keep defaults
  }
}
---

<section id="download" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
      {t.download.title}
    </h2>
    <div class="mt-8">
      <div class="text-sm text-muted-foreground">
        <span>{t.download.latestVersion}</span>
      </div>
      <div class="mt-2 text-4xl font-bold">v{version}</div>
      <div class="mt-1 text-sm text-muted-foreground">{t.download.releaseDate}: {releaseDate}</div>

      <div class="mt-6 flex justify-center">
        <DownloadDialog
          client:load
          downloadText={t.hero.download}
          disclaimerTitle={t.privacy.disclaimer.title}
          disclaimerContent={t.privacy.disclaimer.content}
          agreeText={isEn ? 'Agree & Download' : '同意并下载'}
          cancelText={isEn ? 'Cancel' : '取消'}
        />
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm">
        <a
          href={isEn ? '/en/changelog' : '/changelog'}
          class="inline-flex items-center gap-1.5 text-primary hover:underline"
        >
          <FileText className="w-4 h-4" />
          {t.download.changelogLink}
        </a>
        <a
          href="https://github.com/Youwenqwq/ysu-client/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
        >
          <Code className="w-4 h-4" />
          {t.download.githubFallback}
        </a>
      </div>

      <p class="mt-6 text-xs text-muted-foreground">
        {t.download.systemRequirements}
      </p>

      <div class="mt-10 rounded-2xl border border-border/60 bg-muted/30 p-6">
        <h3 class="text-lg font-semibold">{t.download.demoTitle}</h3>
        <p class="mt-1 text-sm text-muted-foreground">{t.download.demoDesc}</p>
        <div class="mt-4">
          <a
            href="/updates/app-release-demo.apk"
            class="inline-flex items-center gap-2 rounded-xl bg-amber-500 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-amber-500/25 transition-all hover:scale-105 hover:shadow-xl"
          >
            <Download className="w-4 h-4" />
            {t.download.demoBtn}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
