---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { ArrowLeft, Download, AlertTriangle, ExternalLink } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);

const homeUrl = getRelativeLocaleUrl(locale, '/');
---

<Layout title={`${t.faq.title} - ${t.appName}`}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <a
      href={homeUrl}
      class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
    >
      <ArrowLeft className="w-4 h-4" />
      {t.faq.back}
    </a>
    <h1 class="text-3xl font-bold">{t.faq.title}</h1>

    <div class="mt-8 space-y-8">

      <section class="rounded-2xl border border-border bg-card p-6">
        <div class="flex items-center gap-3 mb-4">
          <AlertTriangle className="w-6 h-6 text-primary" />
          <h2 class="text-xl font-semibold">{t.faq.compatibility.title}</h2>
        </div>
        <p class="text-muted-foreground leading-relaxed mb-4">{t.faq.compatibility.intro}</p>
        <ul class="space-y-3 mb-4">
          {t.faq.compatibility.versions.map((v: { label: string; desc: string }) => (
            <li class="text-muted-foreground">
              <span class="font-medium text-foreground">{v.label}</span>{' '}{v.desc}
            </li>
          ))}
        </ul>
        <p class="text-muted-foreground leading-relaxed">{t.faq.compatibility.recommendation}</p>
      </section>

      <section class="rounded-2xl border border-border bg-card p-6">
        <div class="flex items-center gap-3 mb-4">
          <Download className="w-6 h-6 text-primary" />
          <h2 class="text-xl font-semibold">{t.faq.webviewUpdate.title}</h2>
        </div>
        <p class="text-muted-foreground leading-relaxed mb-6">{t.faq.webviewUpdate.intro}</p>

        <div class="space-y-6">
          <div>
            <h3 class="font-medium mb-2">{t.faq.webviewUpdate.play.title}</h3>
            <p class="text-muted-foreground leading-relaxed mb-2">{t.faq.webviewUpdate.play.desc}</p>
            <a
              href={t.faq.webviewUpdate.play.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-primary hover:underline"
            >
              <ExternalLink className="w-4 h-4" />
              {t.faq.webviewUpdate.play.linkText}
            </a>
          </div>

          <div>
            <h3 class="font-medium mb-2">{t.faq.webviewUpdate.manual.title}</h3>
            <p class="text-muted-foreground leading-relaxed">{t.faq.webviewUpdate.manual.desc}</p>
          </div>

          <div class="rounded-lg bg-muted p-4">
            <h3 class="font-medium mb-2">{t.faq.webviewUpdate.huawei.title}</h3>
            <p class="text-muted-foreground leading-relaxed">{t.faq.webviewUpdate.huawei.desc}</p>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
