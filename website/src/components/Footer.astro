---
import { Code, ExternalLink, FileText, Shield } from 'lucide-react';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);
const isEn = locale === 'en';
---

<footer class="border-t border-border bg-muted/30 px-4 py-12 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-center gap-6 text-center">
      <div class="flex flex-wrap items-center justify-center gap-4 text-sm">
        <a
          href={isEn ? '/en/changelog' : '/changelog'}
          class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
        >
          <FileText className="w-4 h-4" />
          {t.nav.changelog}
        </a>
        <span class="text-border">·</span>
        <a
          href={isEn ? '/en/privacy' : '/privacy'}
          class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
        >
          <Shield className="w-4 h-4" />
          {t.nav.privacy}
        </a>
        <span class="text-border">·</span>
        <a
          href="https://github.com/Youwenqwq/ysu-client"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-foreground hover:text-primary transition-colors"
        >
          <Code className="w-4 h-4" />
          {t.footer.sourceCode}
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-muted-foreground">
        <a
          href="https://github.com/Youwenqwq/ysu-sdk"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 hover:text-foreground transition-colors"
        >
          ysu-sdk
          <ExternalLink className="w-3 h-3" />
        </a>
        <a
          href="https://github.com/Youwenqwq/ysu-api"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 hover:text-foreground transition-colors"
        >
          ysu-api
          <ExternalLink className="w-3 h-3" />
        </a>
      </div>

      <p class="text-sm text-muted-foreground max-w-lg">
        {t.footer.disclaimer}
      </p>

      <div class="text-xs text-muted-foreground">
        <span>{t.footer.license}</span>
        <span class="mx-2">·</span>
        <span>{t.footer.copyright}</span>
      </div>
    </div>
  </div>
</footer>