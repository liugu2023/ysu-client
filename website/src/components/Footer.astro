---
const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);
const site = await import('../data/site.json').then(m => m.default);
---

<footer class="mt-auto border-t border-border bg-muted/30 px-4 py-10 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-center gap-4 text-center">
      <p class="text-sm text-muted-foreground max-w-lg">
        {t.footer.disclaimer}
      </p>

      <div class="text-xs text-muted-foreground">
        <span>{t.footer.license}</span>
        <span class="mx-2">·</span>
        <span>{t.footer.copyright}</span>
      </div>

      <div id="daily-stats" class="text-[10px] text-muted-foreground/30 tabular-nums" aria-live="polite" />

      <div class="flex flex-col items-center gap-1 text-xs text-muted-foreground/60">
        <a href={site.icp.href} target="_blank" rel="noopener noreferrer" class="hover:text-muted-foreground transition-colors">
          {site.icp.text}
        </a>
        <a href={site.beian.href} target="_blank" rel="noopener noreferrer" class="hover:text-muted-foreground transition-colors">
          {site.beian.text}
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  (function () {
    const el = document.getElementById('daily-stats');
    if (!el) return;
    fetch('/api/stats')
      .then((r) => r.json())
      .then((data) => {
        if (typeof data.count === 'number') {
          el.textContent = '今日活跃 ' + data.count.toLocaleString() + ' 人';
        }
      })
      .catch(() => {
        // Silently ignore — stats must not break the page
      });
  })();
</script>
