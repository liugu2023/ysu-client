---
import ThemeToggle from './ThemeToggle';
import LangSwitch from './LangSwitch';
import MobileNav from './MobileNav';

const locale = Astro.currentLocale ?? 'zh';
const isEn = locale === 'en';

const t = await import(`../i18n/${locale}.json`).then(m => m.default);

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/en' || pathname === '/en/';
const homePrefix = isEn ? '/en/' : '/';

const navItems = [
  { label: t.nav.features, href: isHome ? '#features' : `${homePrefix}#features` },
  { label: t.nav.screenshots, href: isEn ? '/en/screenshots' : '/screenshots' },
  { label: t.nav.download, href: isHome ? '#download' : `${homePrefix}#download` },
  { label: t.nav.faq, href: isEn ? '/en/faq' : '/faq' },
];

const switchUrl = isEn ? '/' : '/en/';
const switchLabel = isEn ? t.lang.switch : 'English';
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center px-4 sm:px-6">
    <div class="flex-1 flex items-center">
      <a href={isEn ? '/en/' : '/'} class="text-lg font-semibold">
        {t.appName}
      </a>
    </div>

    <nav class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a href={item.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex-1 flex items-center justify-end gap-1">
      <LangSwitch client:load currentLang={locale} switchLabel={switchLabel} switchUrl={switchUrl} />
      <ThemeToggle client:load />
      <MobileNav client:load items={navItems} />
    </div>
  </div>
</header>
