---
import ThemeToggle from './ThemeToggle';
import LangSwitch from './LangSwitch';

const locale = Astro.currentLocale ?? 'zh';
const isEn = locale === 'en';

const t = await import(`../i18n/${locale}.json`).then(m => m.default);

const navItems = [
  { label: t.nav.features, href: '#features' },
  { label: t.nav.screenshots, href: '#screenshots' },
  { label: t.nav.download, href: '#download' },
];

const switchUrl = isEn ? '/' : '/en/';
const switchLabel = isEn ? t.lang.switch : 'English';
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href={isEn ? '/en/' : '/'} class="flex items-center gap-2 text-lg font-semibold">
      <img src="/favicon.ico" alt="" class="h-8 w-8 rounded" />
      <span>{t.appName}</span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a href={item.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1">
      <LangSwitch client:load currentLang={locale} switchLabel={switchLabel} switchUrl={switchUrl} />
      <ThemeToggle client:load />
    </div>
  </div>
</header>
