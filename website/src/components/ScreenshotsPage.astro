---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ScreenshotViewer from './ScreenshotViewer';
import { ArrowLeft } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);

const homeUrl = getRelativeLocaleUrl(locale, '/');

const screenshots = locale === 'en'
  ? [
      { label: 'Overview', src: '/images/screenshots/overview.jpg', srcDark: '/images/screenshots/overview-dark.jpg' },
      { label: 'Schedule', src: '/images/screenshots/schedule.jpg', srcDark: '/images/screenshots/schedule-dark.jpg' },
      { label: 'Grades', src: '/images/screenshots/grades.jpg', srcDark: '/images/screenshots/grades-dark.jpg' },
      { label: 'Evaluation', src: '/images/screenshots/evaluation.jpg', srcDark: '/images/screenshots/evaluation-dark.jpg' },
      { label: 'Profile', src: '/images/screenshots/me.jpg', srcDark: '/images/screenshots/me-dark.jpg' },
      { label: 'Settings', src: '/images/screenshots/settings.jpg', srcDark: '/images/screenshots/settings-dark.jpg' },
    ]
  : [
      { label: '总览', src: '/images/screenshots/overview.jpg', srcDark: '/images/screenshots/overview-dark.jpg' },
      { label: '课程表', src: '/images/screenshots/schedule.jpg', srcDark: '/images/screenshots/schedule-dark.jpg' },
      { label: '成绩查询', src: '/images/screenshots/grades.jpg', srcDark: '/images/screenshots/grades-dark.jpg' },
      { label: '学生评教', src: '/images/screenshots/evaluation.jpg', srcDark: '/images/screenshots/evaluation-dark.jpg' },
      { label: '我的', src: '/images/screenshots/me.jpg', srcDark: '/images/screenshots/me-dark.jpg' },
      { label: '设置', src: '/images/screenshots/settings.jpg', srcDark: '/images/screenshots/settings-dark.jpg' },
    ];
---

<Layout title={`${t.screenshots.title} - ${t.appName}`}>
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-12 sm:px-6 overflow-x-hidden">
    <a
      href={homeUrl}
      class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
    >
      <ArrowLeft className="w-4 h-4" />
      {t.changelog.back}
    </a>

    <h1 class="text-3xl font-bold">{t.screenshots.title}</h1>
    <p class="mt-2 text-muted-foreground">{t.screenshots.subtitle}</p>

    <div class="mt-8">
      <ScreenshotViewer client:load images={screenshots} />
    </div>
  </main>
  <Footer />
</Layout>
