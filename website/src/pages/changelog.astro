---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ArrowLeft } from 'lucide-react';

const t = await import('../i18n/zh.json').then(m => m.default);
const changelog = await import('../data/changelog.json').then(m => m.default);
---

<Layout title={`${t.changelog.title} - ${t.appName}`}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
    >
      <ArrowLeft className="w-4 h-4" />
      {t.changelog.back}
    </a>
    <h1 class="text-3xl font-bold">{t.changelog.title}</h1>
    <div class="mt-8 space-y-8">
      {changelog.map(item => (
        <div class="rounded-2xl border border-border bg-card p-6">
          <div class="flex items-center gap-3">
            <span class="text-xl font-bold">v{item.version}</span>
            <span class="text-sm text-muted-foreground">{item.date}</span>
          </div>
          <ul class="mt-4 space-y-2">
            {item.changes.map(change => (
              <li class="flex items-start gap-2 text-sm">
                <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-primary flex-shrink-0" />
                <span>{change}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Layout>
